{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/gemini.js",     "use": "@vercel/node", "config": { "maxDuration": 30 } },
    { "src": "api/ocr-image.js",  "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/tts.js",        "use": "@vercel/node", "config": { "maxDuration": 30 } }
  ],
  "routes": [
    { "src": "/api/gemini",    "dest": "/api/gemini.js" },
    { "src": "/api/ocr-image", "dest": "/api/ocr-image.js" },
    { "src": "/api/tts",       "dest": "/api/tts.js" },
    { "src": "/api/(.*)",      "dest": "https://cipp-legal-api.onrender.com/api/$1" },
    { "src": "/(.*)",          "dest": "/public/index.html" }
  ]
}
